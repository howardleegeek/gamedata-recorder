# GameData Labs Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# SECURITY SETTINGS (REQUIRED FOR PRODUCTION)
# =============================================================================

# API Secret Key - Generate with: openssl rand -hex 32
# This is used for token signing. MUST be changed for production!
API_SECRET=your-secure-secret-key-here-change-this-in-production

# Allowed CORS Origins - Comma-separated list of allowed frontend URLs
# For production, restrict to your actual domain(s)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://gamedatalabs.com

# =============================================================================
# AWS S3 CONFIGURATION (OPTIONAL - for cloud storage)
# =============================================================================

# S3 Bucket name for storing recordings
S3_BUCKET=gamedata-recordings

# AWS Region
S3_REGION=us-east-1

# AWS Credentials (if not using IAM role/instance profile)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# =============================================================================
# DATA STORAGE CONFIGURATION
# =============================================================================

# Local data directory (used when S3 is not configured)
# Default: ./data
DATA_DIR=./data

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server port
PORT=8000

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# DEVELOPMENT SETTINGS (DO NOT USE IN PRODUCTION)
# =============================================================================

# Set to 'true' to enable auto-reload during development
DEBUG=false
